# ==========================
# Application
# ==========================
APP_NAME=GenAI RAG Chatbot
APP_VERSION=1.0.0

# ==========================
# Server
# ==========================
HOST=127.0.0.1
PORT=8000

# ==========================
# Ollama
# ==========================
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=llama3
OLLAMA_TIMEOUT=120

# ==========================
# PDF Processing
# ==========================
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ==========================
# Storage
# ==========================
VECTOR_DB=faiss
DATA_FOLDER=data/pdfs
VECTOR_STORE=vectorstore/faiss_index

#==============================
#Embedding
#==============================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ==========================
# Retrieval
# ==========================
TOP_K=3

